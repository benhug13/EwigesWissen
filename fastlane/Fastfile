default_platform(:ios)

API_KEY_PATH = File.expand_path("~/.appstoreconnect/private_keys/AuthKey_1A4EOTQ8Y2MN.p8")
API_KEY_ID = "1A4EOTQ8Y2MN"
API_ISSUER_ID = "d47ec6ac-49e9-4f30-8695-016b515d3d2f"

platform :ios do
  before_all do
    ENV["FASTLANE_XCODEBUILD_SETTINGS_TIMEOUT"] = "120"
  end

  desc "Regenerate Xcode project and bump build number"
  private_lane :prepare do
    build_number = sh("git rev-list --count HEAD").strip
    File.write("../BuildNumber.xcconfig", "BUILD_NUMBER = #{build_number}\n")
    sh("sed -i '' \"s/CURRENT_PROJECT_VERSION: .*/CURRENT_PROJECT_VERSION: \\\"#{build_number}\\\"/\" ../project.yml")
    xcodegen_path = File.expand_path("~/.local/bin/xcodegen-2.39")
    if File.executable?(xcodegen_path)
      sh("cd .. && #{xcodegen_path} generate")
    else
      sh("cd .. && xcodegen generate")
    end
    build_number
  end

  desc "Upload a new build to TestFlight"
  lane :beta do
    build_number = prepare

    api_key = app_store_connect_api_key(
      key_id: API_KEY_ID,
      issuer_id: API_ISSUER_ID,
      key_filepath: API_KEY_PATH,
      duration: 1200,
      in_house: false
    )

    build_app(
      project: "EwigesWissen.xcodeproj",
      scheme: "EwigesWissen",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "EwigesWissen.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      ipa: "build/EwigesWissen.ipa"
    )
  end

  desc "Submit the latest TestFlight build for App Store review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: API_KEY_ID,
      issuer_id: API_ISSUER_ID,
      key_filepath: API_KEY_PATH,
      duration: 1200,
      in_house: false
    )

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false
    )
  end
end
